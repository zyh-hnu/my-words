# 环境变量配置示例
# 复制此文件为 .env 并填入你的API密钥

# OpenAI 兼容 API 配置
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# 或者使用 DeepSeek API（推荐，性价比高）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com

# Newsletter 输出目录（可选，默认为项目根目录下的 newsletters）
# NEWSLETTER_DIR=/path/to/newsletters

# PushDeer 推送通知（可选，用于接收生成状态通知）
# PUSH_DEER_KEY=your_push_deer_key

# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入你的 API 密钥
# 3. 运行: cd script/newsletter && uv run main.py
